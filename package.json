{
  "name": "zero-to-ai",
  "version": "1.1.0",
  "description": "从零开始用 AI 编程工具 — 实战教程集合",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run validate-refs && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-refs": "tsx scripts/validate-cross-refs.ts",
    "audit:content-freshness": "tsx scripts/audit-content-freshness.ts",
    "audit:official-links": "tsx scripts/audit-official-links.ts",
    "build:skill-pack": "python3 scripts/build-skill-pack.py",
    "test:skill-pack": "npm run build:skill-pack && python3 scripts/test-skill-pack.py",
    "test:fixtures": "tsx scripts/test-claude-fixtures.ts",
    "test:unit": "tsx --test tests/unit/*.test.ts",
    "test:e2e:run": "playwright test",
    "test:e2e": "npm run build && npm run test:e2e:run",
    "verify": "npm run check && npm run lint && npm run format:check && npm run audit:content-freshness && npm run test:fixtures && npm run test:skill-pack && npm run test:unit && npm run test:e2e",
    "clean": "rm -rf dist .astro"
  },
  "keywords": [
    "ai-coding",
    "claude-code",
    "tutorial",
    "astro",
    "starlight"
  ],
  "author": "Jason <https://github.com/estelledc>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/estelledc/zero-to-ai.git"
  },
  "homepage": "https://estelledc.github.io/zero-to-ai/",
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.0.7",
    "sharp": "^0.35.3",
    "starlight-base-path": "^0.2.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "gray-matter": "^4.0.3",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "gray-matter": {
      "js-yaml": "3.15.0"
    }
  }
}
