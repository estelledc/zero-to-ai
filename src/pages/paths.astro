---
import { learningPaths } from '../data/learning-paths';
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import DifficultyBadge from '../components/DifficultyBadge.astro';
import { slugToHref } from '../utils/base-url';
import { findDoc } from '../utils/find-doc';

const allDocs = await getCollection('docs');

const pathsWithTutorialInfo = learningPaths.map((path) => ({
  ...path,
  tutorialDetails: path.tutorials.map((slug) => {
    const doc = findDoc(allDocs, slug);
    return {
      slug,
      title: doc?.data.title || slug,
      difficulty: doc?.data.difficulty as 'beginner' | 'intermediate' | 'advanced' | undefined,
    };
  }),
}));
---

<StarlightPage frontmatter={{ title: '学习路径' }}>
  <p class="paths-intro">
    不知道从哪开始？选一条适合你的路径，跟着走就行。每条路径是一系列教程的有序串联，从入门到交付。
  </p>

  {
    pathsWithTutorialInfo.map((path) => (
      <section id={path.slug} class="path-card">
        <h2>{path.title}</h2>
        <p>{path.description}</p>
        <p class="path-card__meta">
          适合：{path.targetAudience} &middot; 预估时间：{path.timeRange}
        </p>
        <p>
          <strong>最终产物：</strong>
          {path.outcome}
        </p>
        <div class="path-card__outcomes">
          <div>
            <strong>里程碑</strong>
            <ul>
              {path.milestones.map((milestone) => (
                <li>{milestone}</li>
              ))}
            </ul>
          </div>
          <div>
            <strong>完成证据</strong>
            <ul>
              {path.completionEvidence.map((evidence) => (
                <li>{evidence}</li>
              ))}
            </ul>
          </div>
          <div>
            <strong>失败恢复</strong>
            <ul>
              {path.recoveryGuidance.map((guidance) => (
                <li>{guidance}</li>
              ))}
            </ul>
          </div>
        </div>

        <ol class="path-card__list" data-path-slug={path.slug}>
          {path.tutorialDetails.map((t) => (
            <li data-tutorial-slug={t.slug}>
              <a href={slugToHref(t.slug, path.slug)}>{t.title}</a>
              {t.difficulty && <DifficultyBadge difficulty={t.difficulty} />}
            </li>
          ))}
        </ol>

        <a href={slugToHref(path.tutorials[0], path.slug)} class="path-card__cta">
          开始这条路径 &rarr;
        </a>
      </section>
    ))
  }

  <p class="paths-reset">
    <button type="button" class="paths-reset__btn" id="reset-progress">重置全部学习进度</button>
  </p>
</StarlightPage>

<style>
  .paths-intro {
    margin-bottom: 2rem;
  }

  .path-card {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
  }

  .path-card h2 {
    margin-top: 0;
  }

  .path-card__meta {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
  }

  .path-card__list {
    padding-left: 1.25rem;
  }

  .path-card__outcomes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 1rem 0;
  }

  .path-card__outcomes ul {
    margin: 0.25rem 0 0;
    padding-left: 1.25rem;
  }

  .path-card__list li {
    margin-bottom: 0.25rem;
  }

  .path-card__cta {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 600;
  }

  .path-card__list li[data-completed] a::before {
    content: '\2713\00a0';
    color: var(--sl-color-green-high);
  }

  .path-card__list li[data-visited] a::before {
    content: '\2022\00a0';
    color: var(--sl-color-gray-3);
  }

  .path-card__list li[data-completed] {
    opacity: 0.75;
  }

  .path-card__progress {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    margin-top: 0.25rem;
  }

  .paths-reset {
    margin-top: 2rem;
    text-align: center;
  }

  .paths-reset__btn {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    background: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
  }

  .paths-reset__btn:hover {
    color: var(--sl-color-text);
    border-color: var(--sl-color-gray-4);
  }

  @media (max-width: 40rem) {
    .path-card__outcomes {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { learningPaths } from '../data/learning-paths';
  import {
    ACTIVE_PATH_KEY,
    ownedProgressKeys,
    readProgress,
    safeRemove,
  } from '../utils/progress-storage';

  function applyProgressMarkers() {
    document
      .querySelectorAll<HTMLOListElement>('.path-card__list[data-path-slug]')
      .forEach((list) => {
        const pathSlug = list.dataset.pathSlug;
        if (!pathSlug) return;

        list.parentElement?.querySelector('.path-card__progress')?.remove();

        let visited = 0;
        let total = 0;

        list.querySelectorAll<HTMLLIElement>('li[data-tutorial-slug]').forEach((li) => {
          total++;
          li.removeAttribute('data-visited');
          li.removeAttribute('data-completed');
          const slug = li.dataset.tutorialSlug;
          if (!slug) return;

          const entry = readProgress(localStorage, pathSlug, slug);
          if (entry?.status === 'completed') {
            li.setAttribute('data-completed', '');
            visited++;
          } else if (entry?.status === 'visited') {
            li.setAttribute('data-visited', '');
          }
        });

        if (visited > 0) {
          const info = document.createElement('p');
          info.className = 'path-card__progress';
          info.textContent = `已完成 ${visited} / ${total} 篇`;
          list.after(info);
        }
      });
  }

  applyProgressMarkers();

  document.getElementById('reset-progress')?.addEventListener('click', () => {
    if (!confirm('确定要清除所有学习路径的进度记录吗？此操作不可撤销。')) return;

    ownedProgressKeys(learningPaths).forEach((key) => safeRemove(localStorage, key));
    safeRemove(localStorage, ACTIVE_PATH_KEY);
    applyProgressMarkers();
  });
</script>
