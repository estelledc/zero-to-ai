---
/**
 * ContentHeader — renders difficulty badge, learning path banner, and path progress.
 * Injected automatically via PageTitle override; no manual import needed in .md files.
 */
import DifficultyBadge from './DifficultyBadge.astro';
import PathProgress from './PathProgress.astro';
import PrerequisitesBar from './PrerequisitesBar.astro';
import { learningPaths } from '../data/learning-paths';
import { getCollection } from 'astro:content';
import { base } from '../utils/base-url';
import { findDoc } from '../utils/find-doc';
import { slugMatches, resolveCanonicalSlug } from '../utils/slug-match';

const route = Astro.locals.starlightRoute;
const entry = route.entry;

const difficulty = entry.data.difficulty as 'beginner' | 'intermediate' | 'advanced' | undefined;
const lastVerified = entry.data.lastVerified as string | undefined;
const toolVersion = entry.data.toolVersion as string | undefined;

const pageId = entry.id;
const belongsTo = pageId
  ? learningPaths.filter((p) => p.tutorials.some((t) => slugMatches(t, pageId)))
  : [];

const allDocs = belongsTo.length > 0 ? await getCollection('docs') : [];

const pathsProgress = belongsTo.map((path) => ({
  slug: path.slug,
  tutorials: path.tutorials.map((slug) => {
    const doc = findDoc(allDocs, slug);
    return { slug, title: doc?.data.title || slug };
  }),
  currentSlug: resolveCanonicalSlug(pageId, path.tutorials),
}));

const pathSlugs = pathsProgress.map((p) => p.slug);
const isMultiPath = pathsProgress.length > 1;

const hasPrerequisites =
  Array.isArray(entry.data.prerequisites) && entry.data.prerequisites.length > 0;
const showHeader =
  difficulty || belongsTo.length > 0 || hasPrerequisites || lastVerified || toolVersion;
---

{
  showHeader && (
    <div class="content-header">
      {difficulty && (
        <div class="content-header__badge">
          <DifficultyBadge difficulty={difficulty} />
        </div>
      )}

      {(lastVerified || toolVersion) && (
        <p class="content-header__meta">
          {lastVerified && <span>内容验证于 {lastVerified}</span>}
          {lastVerified && toolVersion && <span aria-hidden="true"> · </span>}
          {toolVersion && <span>适用 {toolVersion}</span>}
        </p>
      )}

      {belongsTo.length > 0 && (
        <div class="content-header__paths">
          <span>本教程属于学习路径：</span>
          <ul class="content-header__path-list">
            {belongsTo.map((path) => (
              <li>
                <a href={`${base}/paths/#${path.slug}`}>{path.title}</a>
              </li>
            ))}
          </ul>
          <span class="content-header__browse">
            {' '}
            · <a href={`${base}/paths/`}>浏览全部路径</a>
          </span>
        </div>
      )}

      {pathsProgress.length > 0 && pageId && (
        <div class="path-progress-container" data-path-slugs={JSON.stringify(pathSlugs)}>
          {pathsProgress.map((p) => (
            <div
              class="path-progress-wrapper"
              data-path-slug={p.slug}
              hidden={isMultiPath || undefined}
            >
              <PathProgress pathSlug={p.slug} tutorials={p.tutorials} currentSlug={p.currentSlug} />
            </div>
          ))}
          {isMultiPath && (
            <script
              is:inline
              set:html={`(function(){var c=document.currentScript.parentElement;var slugs=${JSON.stringify(pathSlugs)};var params=new URLSearchParams(location.search);var active=params.get('path');if(!active||slugs.indexOf(active)===-1){try{active=localStorage.getItem('zero-to-ai:active-path');}catch(e){}if(!active||slugs.indexOf(active)===-1)active=slugs[0];}try{localStorage.setItem('zero-to-ai:active-path',active);}catch(e){}c.querySelectorAll('.path-progress-wrapper').forEach(function(w){w.hidden=w.dataset.pathSlug!==active;});})();`}
            />
          )}
        </div>
      )}

      <PrerequisitesBar />
    </div>
  )
}

<style>
  .content-header {
    margin-bottom: 1.5rem;
  }

  .content-header__badge {
    margin-bottom: 0.5rem;
  }

  .content-header__meta {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    margin: 0 0 0.5rem;
  }

  .content-header__paths {
    background: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .content-header__path-list {
    display: inline;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .content-header__path-list li {
    display: inline;
  }

  .content-header__path-list li:not(:last-child)::after {
    content: '、';
  }

  .content-header__paths a {
    font-weight: 600;
  }

  .content-header__browse {
    color: var(--sl-color-gray-2);
  }

  .path-progress-container {
    margin-top: 0.25rem;
  }

  .path-progress-wrapper[hidden] {
    display: none !important;
  }
</style>
