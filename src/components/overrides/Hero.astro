---
import { LinkButton } from '@astrojs/starlight/components';
import DraftContentNotice from 'virtual:starlight/components/DraftContentNotice';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, actions = [] } = data.hero || {};
---

<section class="zero-hero" aria-labelledby="_top">
  <div class="zero-hero__copy">
    <div class="zero-hero__eyebrow">
      <span class="jx-chip" data-state="maintained">Maintained</span>
      <span>Chinese AI-coding learning system</span>
    </div>
    <h1 id="_top" data-page-title set:html={title} />
    {data.draft && <DraftContentNotice />}
    {tagline && <p class="zero-hero__tagline" set:html={tagline} />}
    <p class="zero-hero__summary-en" lang="en">
      From first prompt to a public project — guided by primary sources, explicit evidence and
      repeatable verification.
    </p>
    {
      actions.length > 0 && (
        <div class="zero-hero__actions">
          {actions.map(
            ({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => (
              <LinkButton
                href={href}
                variant={variant}
                icon={icon?.name}
                class:list={[className]}
                {...attrs}
              >
                {text}
                {icon?.html && <Fragment set:html={icon.html} />}
              </LinkButton>
            ),
          )}
        </div>
      )
    }
  </div>

  <div class="zero-hero__map" aria-label="学习系统由四个阶段组成">
    <div class="zero-hero__map-head">
      <span>path://zero-to-ai</span>
      <span class="zero-hero__pulse">live</span>
    </div>
    <ol>
      <li>
        <span>01</span>
        <div><strong>选路</strong><small>从目标与成本开始</small></div>
      </li>
      <li>
        <span>02</span>
        <div><strong>动手</strong><small>完成工具专属闭环</small></div>
      </li>
      <li>
        <span>03</span>
        <div><strong>验证</strong><small>用测试而非感觉判断</small></div>
      </li>
      <li>
        <span>04</span>
        <div><strong>公开</strong><small>交付一个可访问作品</small></div>
      </li>
    </ol>
    <p><strong>4</strong> learning paths <span>·</span> 从目标与成本开始，不从目录开始</p>
  </div>
</section>

<style>
  @layer starlight.core {
    .zero-hero {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(17rem, 0.8fr);
      align-items: center;
      gap: clamp(2rem, 7vw, 6rem);
      padding-block: clamp(3.25rem, 9vw, 7rem);
    }

    .zero-hero::before {
      content: '';
      position: absolute;
      inset: 10% 38% auto -20%;
      height: 18rem;
      z-index: -1;
      background: radial-gradient(
        circle,
        color-mix(in oklab, var(--sl-color-accent), transparent 80%),
        transparent 68%
      );
      filter: blur(24px);
      pointer-events: none;
    }

    .zero-hero__copy {
      min-width: 0;
    }

    .zero-hero__eyebrow {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      color: var(--sl-color-gray-3);
      font-family: var(--jx-font-mono);
      font-size: var(--jx-fs-micro);
      letter-spacing: var(--jx-tracking-eyebrow);
      text-transform: uppercase;
    }

    h1 {
      max-width: 10ch;
      margin: 0;
      color: var(--sl-color-white);
      font-family: var(--jx-font-display);
      font-size: clamp(3.25rem, 8vw, 6.5rem);
      font-weight: 600;
      line-height: 0.94;
      letter-spacing: -0.055em;
    }

    .zero-hero__tagline {
      max-width: 34em;
      margin: 1.5rem 0 0;
      color: var(--sl-color-gray-1);
      font-size: clamp(1.05rem, 2vw, 1.35rem);
      line-height: 1.65;
    }

    .zero-hero__summary-en {
      max-width: 42em;
      margin: 0.85rem 0 0;
      color: var(--sl-color-gray-3);
      font-family: var(--jx-font-sans-latin);
      font-size: 0.82rem;
      line-height: 1.6;
    }

    .zero-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1.25rem;
      margin-top: 2rem;
    }

    .zero-hero__map {
      overflow: hidden;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 1rem;
      background:
        linear-gradient(var(--sl-color-hairline) 1px, transparent 1px),
        linear-gradient(90deg, var(--sl-color-hairline) 1px, transparent 1px),
        color-mix(in oklab, var(--sl-color-bg-nav), transparent 12%);
      background-size: 1.5rem 1.5rem;
      box-shadow: var(--jx-shadow-stack);
    }

    .zero-hero__map-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.85rem 1rem;
      color: var(--sl-color-gray-3);
      background: color-mix(in oklab, var(--sl-color-bg), transparent 8%);
      border-bottom: 1px solid var(--sl-color-gray-5);
      font-family: var(--jx-font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.05em;
    }

    .zero-hero__pulse {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--jx-state-maintained);
    }

    .zero-hero__pulse::before {
      content: '';
      width: 0.4rem;
      height: 0.4rem;
      border-radius: 50%;
      background: currentColor;
      box-shadow: 0 0 0 0.22rem color-mix(in oklab, currentColor, transparent 82%);
    }

    .zero-hero__map ol {
      display: grid;
      gap: 0;
      margin: 0;
      padding: 0.75rem 1rem;
      list-style: none;
    }

    .zero-hero__map li {
      position: relative;
      display: grid;
      grid-template-columns: 2.25rem 1fr;
      align-items: center;
      gap: 0.75rem;
      min-height: 4.25rem;
      padding-block: 0.6rem;
    }

    .zero-hero__map li:not(:last-child)::after {
      content: '';
      position: absolute;
      inset: auto 0 0 3rem;
      border-bottom: 1px solid var(--sl-color-gray-5);
    }

    .zero-hero__map li > span {
      color: var(--sl-color-text-accent);
      font-family: var(--jx-font-mono);
      font-size: 0.72rem;
    }

    .zero-hero__map strong,
    .zero-hero__map small {
      display: block;
    }

    .zero-hero__map strong {
      color: var(--sl-color-white);
      font-size: 0.92rem;
    }

    .zero-hero__map small {
      margin-top: 0.2rem;
      color: var(--sl-color-gray-3);
      font-size: 0.73rem;
    }

    .zero-hero__map > p {
      margin: 0;
      padding: 0.85rem 1rem;
      color: var(--sl-color-gray-3);
      background: color-mix(in oklab, var(--sl-color-bg), transparent 8%);
      border-top: 1px solid var(--sl-color-gray-5);
      font-family: var(--jx-font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.03em;
    }

    .zero-hero__map > p strong {
      display: inline;
      color: var(--sl-color-text-accent);
      font-family: inherit;
      font-size: inherit;
    }

    @media (max-width: 49.99rem) {
      .zero-hero {
        grid-template-columns: 1fr;
        padding-block: 2.75rem 3.5rem;
      }

      h1 {
        font-size: clamp(3rem, 17vw, 5rem);
      }

      .zero-hero__map {
        display: none;
      }

      .zero-hero__actions :global(.sl-link-button) {
        min-height: 2.75rem;
        justify-content: center;
      }

      .zero-hero__actions :global(.sl-link-button:first-child) {
        flex-basis: 100%;
      }

      .zero-hero__actions :global(.sl-link-button:not(:first-child)) {
        flex: 1 1 9rem;
      }
    }

    @media (max-width: 24rem) {
      .zero-hero__eyebrow > span:last-child {
        display: none;
      }

      .zero-hero__actions :global(.sl-link-button) {
        flex-basis: 100%;
      }
    }
  }
</style>
