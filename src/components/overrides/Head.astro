---
/**
 * Custom Head override that injects search synonyms via data-pagefind-meta.
 *
 * Pagefind 不支持原生同义词，但 data-pagefind-meta 的内容默认可搜索。
 * 通过在 <head> 中注入 <meta> 标签，把口语化关键词编入搜索索引。
 *
 * Replaces @astrojs/starlight/components/Head.astro
 */
import { synonymMap } from '../../data/search-synonyms';
import { slugVariants } from '../../utils/slug-match';
import { base } from '../../utils/base-url';

const { head } = Astro.locals.starlightRoute;
const entry = Astro.locals.starlightRoute.entry;
const pageId = entry.id;

const synonyms = slugVariants(pageId).flatMap((variant) => synonymMap[variant] ?? []);
const uniqueSynonyms = [...new Set(synonyms)];
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
{uniqueSynonyms.length > 0 && <meta data-pagefind-meta={`synonyms:${uniqueSynonyms.join(' ')}`} />}
<link rel="alternate" type="application/rss+xml" title="Zero to AI" href={`${base}/rss.xml`} />
