---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
---

<nav class="showcase-mobile-links" aria-label="作品集导航">
  <a href="https://estelledc.github.io/">作品集</a>
  <a href="https://estelledc.github.io/about/">关于</a>
  <a href="https://estelledc.github.io/resume/">简历</a>
</nav>
<div class="mobile-preferences sl-flex">
  <div class="social-icons"><SocialIcons /></div>
  <ThemeSelect />
  <LanguageSelect />
</div>

<style>
  @layer starlight.core {
    .showcase-mobile-links {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
      padding-block: 1rem;
      border-top: 1px solid var(--sl-color-gray-6);
    }

    .showcase-mobile-links a {
      min-height: 2.75rem;
      display: grid;
      place-items: center;
      color: var(--sl-color-gray-1);
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      font-size: var(--sl-text-sm);
      font-weight: 600;
      text-decoration: none;
    }

    .social-icons {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-inline-end: auto;
      padding-block: 1rem;
    }

    .social-icons:empty {
      display: none;
    }

    .mobile-preferences {
      justify-content: space-between;
      flex-wrap: wrap;
      column-gap: 1rem;
      padding: 0.5rem 0;
      border-top: 1px solid var(--sl-color-gray-6);
    }
  }
</style>
