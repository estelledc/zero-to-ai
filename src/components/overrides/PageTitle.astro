---
/**
 * Custom PageTitle override that injects ContentHeader (difficulty badge + learning path banner)
 * below the page title on all docs pages.
 *
 * Replaces @astrojs/starlight/components/PageTitle.astro
 */
import ContentHeader from '../ContentHeader.astro';

// Starlight uses '_top' as the page title anchor ID (defined in constants.ts)
const PAGE_TITLE_ID = '_top';
const route = Astro.locals.starlightRoute;
---

<h1 id={PAGE_TITLE_ID}>{route.entry.data.title}</h1>
<ContentHeader />

<style>
  @layer starlight.core {
    h1 {
      margin-top: 1rem;
      font-size: var(--sl-text-h1);
      line-height: var(--sl-line-height-headings);
      font-weight: 600;
      color: var(--sl-color-text);
    }
  }
</style>
