---
/**
 * Custom Footer override that injects RelatedContent links.
 *
 * Replaces @astrojs/starlight/components/Footer.astro
 */
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import config from 'virtual:starlight/user-config';
import { Icon } from '@astrojs/starlight/components';
import RelatedContent from '../RelatedContent.astro';
---

<RelatedContent />

<footer class="sl-flex">
  <div class="meta sl-flex">
    <EditLink />
    <LastUpdated />
  </div>

  <div class="showcase-footer">
    <p>
      <strong>Zero to AI</strong>
      <span>Jason 的公开学习系统作品</span>
    </p>
    <nav aria-label="作品集导航">
      <a href="https://estelledc.github.io/">作品集</a>
      <a href="https://estelledc.github.io/about/">关于</a>
      <a href="https://estelledc.github.io/resume/">简历</a>
      <a href="https://github.com/estelledc/zero-to-ai">源码</a>
    </nav>
  </div>

  {
    config.credits && (
      <a class="kudos sl-flex" href="https://starlight.astro.build">
        <Icon name={'starlight'} /> {Astro.locals.t('builtWithStarlight.label')}
      </a>
    )
  }
</footer>

<script>
  const makeCodeBlocksKeyboardScrollable = () => {
    document.querySelectorAll<HTMLElement>('.expressive-code pre').forEach((block) => {
      block.tabIndex = 0;
    });
  };
  makeCodeBlocksKeyboardScrollable();
  document.addEventListener('astro:page-load', makeCodeBlocksKeyboardScrollable);
</script>

<style>
  @layer starlight.core {
    footer {
      flex-direction: column;
      gap: 1.5rem;
    }
    .meta {
      gap: 0.75rem 3rem;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 3rem;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-3);
    }
    .meta > :global(p:only-child) {
      margin-inline-start: auto;
    }

    .kudos {
      align-items: center;
      gap: 0.5em;
      margin: 1.5rem auto;
      font-size: var(--sl-text-xs);
      text-decoration: none;
      color: var(--sl-color-gray-3);
    }
    .kudos:hover {
      color: var(--sl-color-white);
    }

    .showcase-footer {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 1.5rem;
      padding-block: 1.5rem;
      border-block: 1px solid var(--sl-color-gray-5);
    }

    .showcase-footer p {
      margin: 0;
    }

    .showcase-footer strong,
    .showcase-footer span {
      display: block;
    }

    .showcase-footer strong {
      color: var(--sl-color-white);
      font-size: var(--sl-text-sm);
    }

    .showcase-footer span {
      margin-top: 0.25rem;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-xs);
    }

    .showcase-footer nav {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 0.75rem 1.25rem;
    }

    .showcase-footer a {
      color: var(--sl-color-gray-2);
      font-size: var(--sl-text-xs);
      font-weight: 600;
      text-decoration: none;
    }

    .showcase-footer a:hover {
      color: var(--sl-color-text-accent);
    }

    @media (max-width: 40rem) {
      .showcase-footer {
        flex-direction: column;
      }

      .showcase-footer nav {
        justify-content: flex-start;
      }
    }
  }

  @layer starlight.components {
    .kudos :global(svg) {
      color: var(--sl-color-orange);
    }
  }
</style>
