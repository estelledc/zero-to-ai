---
/**
 * PrerequisitesBar — renders a list of prerequisite tutorials as clickable links.
 * Only renders if the current page has prerequisites defined in frontmatter.
 */
import { getCollection } from 'astro:content';
import { findDoc } from '../utils/find-doc';
import { slugToHref } from '../utils/base-url';

const entry = Astro.locals.starlightRoute.entry;
const prerequisites = (entry.data.prerequisites as string[]) || [];

const allDocs = prerequisites.length > 0 ? await getCollection('docs') : [];

const prereqDetails = prerequisites
  .map((slug) => {
    const doc = findDoc(allDocs, slug);
    return doc ? { slug, title: doc.data.title } : null;
  })
  .filter(Boolean) as { slug: string; title: string }[];
---

{
  prereqDetails.length > 0 && (
    <div class="prerequisites-bar">
      <span class="prerequisites-bar__label" id="prerequisites-label">
        前置要求：
      </span>
      <ul class="prerequisites-bar__list" aria-labelledby="prerequisites-label">
        {prereqDetails.map((p) => (
          <li>
            <a href={slugToHref(p.slug)} data-prereq-link>
              {p.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )
}

<script>
  import { ACTIVE_PATH_KEY } from '../utils/progress-storage';

  const params = new URLSearchParams(window.location.search);
  const queryPath = params.get('path');
  const storedPath = localStorage.getItem(ACTIVE_PATH_KEY);
  const activePath = queryPath || storedPath;

  if (activePath) {
    document.querySelectorAll<HTMLAnchorElement>('a[data-prereq-link]').forEach((link) => {
      const url = new URL(link.href, window.location.origin);
      if (!url.searchParams.has('path')) {
        url.searchParams.set('path', activePath);
        link.href = `${url.pathname}${url.search}`;
      }
    });
  }
</script>

<style>
  .prerequisites-bar {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
    margin-bottom: 0.5rem;
  }

  .prerequisites-bar__label {
    font-weight: 600;
    color: var(--sl-color-gray-3);
  }

  .prerequisites-bar__list {
    display: inline;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .prerequisites-bar__list li {
    display: inline;
  }

  .prerequisites-bar__list li:not(:last-child)::after {
    content: '、';
  }

  .prerequisites-bar a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }

  .prerequisites-bar a:hover {
    text-decoration: underline;
  }
</style>
