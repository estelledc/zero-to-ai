---
export interface Props {
  pathSlug: string;
  tutorials: { slug: string; title: string }[];
  currentSlug: string;
}

import { slugToHref } from '../utils/base-url';

const { pathSlug, tutorials, currentSlug } = Astro.props;
const currentIndex = tutorials.findIndex((t) => t.slug === currentSlug);
const prev = currentIndex > 0 ? tutorials[currentIndex - 1] : null;
const next = currentIndex < tutorials.length - 1 ? tutorials[currentIndex + 1] : null;
---

{
  currentIndex >= 0 && (
    <nav
      class="path-progress"
      aria-label="学习路径进度"
      data-path={pathSlug}
      data-current={currentSlug}
    >
      <div class="path-progress__dots">
        {tutorials.map((t, i) => {
          const isCurrent = i === currentIndex;
          return (
            <a
              href={slugToHref(t.slug)}
              title={t.title}
              data-slug={t.slug}
              class:list={['path-progress__dot', { 'path-progress__dot--current': isCurrent }]}
            >
              <span class="sr-only">{t.title}</span>
            </a>
          );
        })}
      </div>
      <div class="path-progress__nav">
        {prev ? (
          <a href={slugToHref(prev.slug)} class="path-progress__prev">
            &larr; 上一篇：{prev.title}
          </a>
        ) : (
          <span />
        )}
        <span class="path-progress__count">
          {currentIndex + 1} / {tutorials.length}
        </span>
        {next ? (
          <a href={slugToHref(next.slug)} class="path-progress__next">
            下一篇：{next.title} &rarr;
          </a>
        ) : (
          <span class="path-progress__done">路径完成</span>
        )}
      </div>
    </nav>
  )
}

<script>
  /**
   * Progress tracking with content version awareness.
   *
   * Storage format: `path:<pathSlug>:<tutorialSlug>` → JSON `{ v: number }`
   * When PROGRESS_VERSION is bumped (e.g. after a major content rewrite),
   * all stale entries are ignored so users re-read updated tutorials.
   */
  const PROGRESS_VERSION = 1;

  const nav = document.querySelector('.path-progress') as HTMLElement | null;
  if (nav) {
    const path = nav.dataset.path;
    const current = nav.dataset.current;

    // Mark current page as visited (with version)
    if (path && current) {
      localStorage.setItem(`path:${path}:${current}`, JSON.stringify({ v: PROGRESS_VERSION }));
    }

    // Highlight previously visited dots — only if version matches
    nav.querySelectorAll<HTMLAnchorElement>('.path-progress__dot').forEach((dot) => {
      const slug = dot.dataset.slug;
      if (!slug) return;

      const raw = localStorage.getItem(`path:${path}:${slug}`);
      if (!raw) return;

      try {
        const data = JSON.parse(raw);
        if (data.v === PROGRESS_VERSION) {
          dot.classList.add('path-progress__dot--visited');
        }
      } catch {
        // Legacy format ("done") — treat as stale, remove it
        localStorage.removeItem(`path:${path}:${slug}`);
      }
    });
  }
</script>

<style>
  .path-progress {
    padding: 0.75rem 0;
  }

  .path-progress__dots {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: wrap;
  }

  .path-progress__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: transparent;
    transition: all 0.2s;
  }

  .path-progress__dot::after {
    content: '';
    display: block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--sl-color-gray-5);
    transition: background 0.2s;
  }

  .path-progress__dot--visited::after {
    background: var(--sl-color-green-high);
  }

  .path-progress__dot--current::after {
    width: 1rem;
    height: 1rem;
    background: var(--sl-color-text-accent);
  }

  .path-progress__nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.8125rem;
    line-height: 1.4;
  }

  .path-progress__prev,
  .path-progress__next {
    color: var(--sl-color-text-accent);
    text-decoration: none;
    max-width: 40%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .path-progress__prev:hover,
  .path-progress__next:hover {
    text-decoration: underline;
  }

  .path-progress__count {
    color: var(--sl-color-gray-2);
    flex-shrink: 0;
  }

  .path-progress__done {
    color: var(--sl-color-green-high);
    font-weight: 600;
  }
</style>
