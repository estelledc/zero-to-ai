---
export interface Props {
  pathSlug: string;
  tutorials: { slug: string; title: string }[];
  currentSlug: string;
}

const { pathSlug, tutorials, currentSlug } = Astro.props;
const currentIndex = tutorials.findIndex((t) => t.slug === currentSlug);
---

{currentIndex >= 0 && (
  <nav
    class="path-progress"
    aria-label="学习路径进度"
    data-path={pathSlug}
    data-current={currentSlug}
  >
    {tutorials.map((t, i) => {
      const isCurrent = i === currentIndex;
      return (
        <a
          href={`/zero-to-ai/${t.slug}/`}
          title={t.title}
          class:list={['path-progress__dot', { 'path-progress__dot--current': isCurrent }]}
        >
          <span class="sr-only">{t.title}</span>
        </a>
      );
    })}
  </nav>
)}

<script>
  const nav = document.querySelector('.path-progress') as HTMLElement | null;
  if (nav) {
    const path = nav.dataset.path;
    const current = nav.dataset.current;
    if (path && current) {
      localStorage.setItem(`path:${path}:${current}`, 'done');
    }
  }
</script>

<style>
  .path-progress {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.75rem 0;
    flex-wrap: wrap;
  }

  .path-progress__dot {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: var(--sl-color-gray-5);
    transition: all 0.2s;
  }

  .path-progress__dot--current {
    width: 1.5rem;
    height: 1.5rem;
    background: var(--sl-color-text-accent);
  }
</style>
